PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/survey_app
# Optional; defaults to https://sobhaascend.sobhaapps.com (production SPA only)
# CORS_ORIGIN=http://localhost:3010

# Microsoft Entra ID — same app registration as the frontend (SPA client id + tenant id)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id
# Optional: restrict sign-in emails to these domains (comma-separated)
# AZURE_ALLOWED_EMAIL_DOMAINS=yourcompany.com
# Admin access is role-based in MongoDB (User.role: user | admin | super_admin).
# Set the first super admin directly in the database, then manage admins from the dashboard.


# Local dev only — skip JWT verification (never use in production)
# AUTH_DISABLED=true
